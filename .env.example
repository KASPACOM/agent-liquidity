# ============================================
# Agent Liquidity Manager — Environment Config
# ============================================

# ========== REQUIRED (ALL DEPLOYMENTS) ==========

# Wallet private key (hex format with 0x prefix)
# ⚠️ NEVER commit .env with real keys! Use ExternalSecret in k8s.
DEPLOYER_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Primary RPC endpoint
RPC_URL=https://rpc.kasplextest.xyz

# ========== DEX MODULE ==========

# Uniswap V2 Router address
DEX_ROUTER=0x81Cc4e7DbC652ec9168Bc2F4435C02d7F315148e

# Uniswap V2 Factory address
DEX_FACTORY=0x89d5842017ceA7dd18D10EE6c679cE199d2aD99E

# Wrapped KAS token address
WKAS=0xf40178040278E16c8813dB20a84119A605812FB3

# AgentVault contract address (on-chain risk limits enforcer)
VAULT_ADDRESS=0x7edf75ceB2441d80aBC6599CeB4E62Eeb23BB2a9

# LP fee in basis points (100 = 1%)
LP_FEE_BPS=100

# ========== LIQUIDATION MODULE (IGRA ONLY) ==========
# Note: Kasplex has NO Aave. Only set these for IGRA networks (Galleon/Caravel).

# Enable/disable Aave liquidation monitoring
LIQUIDATION_ENABLED=false

# Aave V3 Pool (proxy) address
# AAVE_POOL=0x631BC5c362ce203B6043844f93f2c67D23a87994

# Aave V3 PoolDataProvider address
# AAVE_POOL_DATA_PROVIDER=0x22B9bDEA931cE0b137DAEf80B2228a288ba05835

# Aave V3 Oracle address
# AAVE_ORACLE=0x6f10A47E2Df6138a36Bc785DA927Ea4072fd4c8f

# ========== DATA SOURCES ==========
# Choose ONE of the following methods:

# Method 1: Direct Graph Node Queries (RECOMMENDED for k8s production)
# Only accessible inside k8s cluster. Faster, no cache, real-time.

# IGRA subgraphs (Galleon/Caravel testnet + mainnet)
# IGRA_GRAPH_NODE_URL=http://graph-node-igra.graph-node:8000/subgraphs/name/igra-testnet-v2-core
# IGRA_GRAPH_TOKEN_NODE_URL=http://graph-node-igra.graph-node:8000/subgraphs/name/igra-testnet-tokens

# Kasplex subgraphs (Kasplex testnet + mainnet)
# KASPLEX_GRAPH_NODE_URL=http://graph-node-kasplex.graph-node:8000/subgraphs/name/kasplex-testnet-kas-new-v2-core
# KASPLEX_GRAPH_TOKEN_NODE_URL=http://graph-node-kasplex.graph-node:8000/subgraphs/name/kasplex-testnet-tokens

# Aave subgraph (IGRA only)
# AAVE_SUBGRAPH_URL=http://graph-node-igra.graph-node:8000/subgraphs/name/igra-testnet-aave-v3

# Method 2: Public API (GOOD for local dev and external access)
# Works from anywhere, has caching (~10-30s lag)
API_BASE_URL=https://dev-api-defi.kaspa.com

# ========== OPTIONAL ==========

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Monitoring loop interval in milliseconds (default: 30000 = 30s)
CHECK_INTERVAL_MS=30000

# Max slippage for trades in basis points (default: 100 = 1%)
MAX_SLIPPAGE_BPS=100

# Telegram alerts (future feature)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ========== NETWORK-SPECIFIC CONFIGS ==========
# Uncomment the section for your target network

# --- Kasplex Testnet (167012) — DEX Only ---
# RPC_URL=https://rpc.kasplextest.xyz
# DEX_ROUTER=0x81Cc4e7DbC652ec9168Bc2F4435C02d7F315148e
